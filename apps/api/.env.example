PORT=8080
POSTGRES_USER=dealsignal
POSTGRES_PASSWORD=dealsignal
POSTGRES_DB=dealsignal
DATABASE_URL=postgres://dealsignal:dealsignal@postgres:5432/dealsignal?sslmode=disable
REDIS_URL=redis:6379
JWT_SECRET=change-me-in-production
LOG_LEVEL=info
VERSION=v2.1.2

# MinIO / S3-compatible object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9002
S3_BUCKET=dealsignal
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true

# OnlyOffice Document Server
ONLYOFFICE_URL=http://onlyoffice:80
ONLYOFFICE_JWT_SECRET=change-me-in-production

# OpenAI-compatible LLM (optional; leave empty to disable vector search and assistant)
OPENAI_API_KEY=
# For DeepSeek / self-hosted / Azure OpenAI-compatible endpoints, include the /v1 suffix when needed.
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
# Optional headers for OpenRouter-compatible providers.
OPENAI_REFERER=http://localhost:8080
OPENAI_APP_TITLE=DealSignal
# Domain / SSL (noop = simulated, selfsigned = in-memory dev cert)
BASE_DOMAIN=dealsignal.com
CNAME_TARGET=cname.dealsignal.com
CERT_PROVIDER=noop

# Public URLs used in email links and redirects
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173

# SMTP configuration for transactional emails (optional; leave empty to log to stdout)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@dealsignal.com

# CORS (comma-separated origins; supports exact match and *.dealsignal.com wildcard)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate limits (requests per minute)
RATE_LIMIT_PUBLIC_RPM=100
RATE_LIMIT_AUTH_RPM=20
RATE_LIMIT_UPLOAD_RPM=10
RATE_LIMIT_WORKSPACE_RPM=200

# Idempotency cache (hours and max cached response body bytes)
IDEMPOTENCY_TTL_HOURS=24
IDEMPOTENCY_MAX_BODY_SIZE=1048576

# Observability
METRICS_ENABLED=true
PPROF_ENABLED=false
