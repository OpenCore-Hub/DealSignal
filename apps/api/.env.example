PORT=8080
APP_ENV=development
POSTGRES_USER=dealsignal
POSTGRES_PASSWORD=dealsignal
POSTGRES_DB=dealsignal
DATABASE_URL=postgres://dealsignal:dealsignal@postgres:5432/dealsignal?sslmode=disable
REDIS_URL=redis:6379
JWT_SECRET=change-me-in-production
LINK_SESSION_SECRET=change-me-in-production
LOG_LEVEL=info
VERSION=v2.1.2

# MinIO / S3-compatible object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9002
S3_BUCKET=dealsignal
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true

# OnlyOffice Document Server
ONLYOFFICE_URL=http://onlyoffice:80
ONLYOFFICE_JWT_SECRET=change-me-in-production

# OpenAI-compatible LLM (optional; leave empty to disable vector search and assistant)
OPENAI_API_KEY=
# For DeepSeek / self-hosted / Azure OpenAI-compatible endpoints, include the /v1 suffix when needed.
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
# Optional headers for OpenRouter-compatible providers.
OPENAI_REFERER=http://localhost:8080
OPENAI_APP_TITLE=DealSignal
# Domain / SSL (noop = simulated, selfsigned = in-memory dev cert)
BASE_DOMAIN=dealsignal.com
CNAME_TARGET=cname.dealsignal.com
CERT_PROVIDER=noop

# Public URLs used in email links and redirects
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173
# Optional: public viewer base URL for share links. Defaults to FRONTEND_URL.
VIEWER_BASE_URL=

# HubSpot OAuth credentials (optional; leave empty to disable HubSpot integration)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# SMTP configuration for transactional emails (optional; leave empty to log to stdout)
# For production, use a trusted SMTP relay on port 587/465 with valid TLS certificates.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@dealsignal.com
# Set to true to skip TLS certificate verification. ONLY for local development or test sandboxes.
# In production this must be false or the server will refuse to start.
SMTP_INSECURE_SKIP_VERIFY=false
SMTP_TIMEOUT_SECONDS=10
SMTP_MAX_RETRIES=3
SMTP_POOL_MAX_CONNS=10
SMTP_POOL_IDLE_TIMEOUT_SECONDS=60
SMTP_POOL_MAX_LIFETIME_SECONDS=300
SMTP_POOL_MAX_USES=100

# Resend configuration (optional; takes precedence over SMTP if set)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@dealsignal.com
RESEND_TIMEOUT_SECONDS=10
RESEND_MAX_RETRIES=3
# Optional: verify Resend webhook signatures (format whsec_...)
RESEND_WEBHOOK_SECRET=

# Branding / localization
DEFAULT_BRAND_NAME=DealSignal
VERIFICATION_TOKEN_TTL_HOURS=24

# Async email queue (Redis Streams). Set to true for production-grade delivery.
EMAIL_QUEUE_ENABLED=false
EMAIL_QUEUE_STREAM=mail:queue
EMAIL_WORKER_COUNT=2
EMAIL_WORKER_INTERVAL_MS=1000
EMAIL_QUEUE_MAX_ATTEMPTS=3
EMAIL_BATCH_SIZE=100
EMAIL_WORKER_BATCH_SIZE=10
# Optional: secret for signing email open/click tracking tokens. Leave empty to disable tracking.
EMAIL_TRACKING_SECRET=change-me-in-production
EMAIL_TRACKING_TTL_HOURS=168
EMAIL_RETRY_BACKOFF_BASE_SECONDS=5
EMAIL_RETRY_BACKOFF_MAX_SECONDS=3600

# CORS (comma-separated origins; supports exact match and *.dealsignal.com wildcard)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate limits (requests per minute)
RATE_LIMIT_PUBLIC_RPM=100
RATE_LIMIT_AUTH_RPM=20
RATE_LIMIT_UPLOAD_RPM=10
RATE_LIMIT_WORKSPACE_RPM=200

# Idempotency cache (hours and max cached response body bytes)
IDEMPOTENCY_TTL_HOURS=24
IDEMPOTENCY_MAX_BODY_SIZE=1048576

# Event deduplication windows (minutes). Redis is used when available and enabled.
LINK_OPEN_DEDUP_WINDOW_MINUTES=30
PAGE_VIEW_DEDUP_WINDOW_MINUTES=5
DEDUP_REDIS_ENABLED=true

# HMAC secret for signing page image and download proxy URLs.
# Must be different from JWT_SECRET and LINK_SESSION_SECRET.
# Generate with: openssl rand -hex 32
URL_SIGNING_SECRET=change-me-in-production

# Security anomaly detection thresholds
SECURITY_ANOMALY_WINDOW_MINUTES=5
SECURITY_ANOMALY_THRESHOLD=5

# Event retention (days). Events older than these thresholds are cleaned up daily.
ACCESS_LOGS_RETENTION_DAYS=90
PAGE_VIEWS_RETENTION_DAYS=90
SECURITY_EVENTS_RETENTION_DAYS=180

# Observability
METRICS_ENABLED=true
PPROF_ENABLED=false
