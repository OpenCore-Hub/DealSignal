{
  "name": "dealsignal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Secure document sharing, deal room, and intent analytics platform",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @dealsignal/api dev",
    "dev:web": "pnpm --filter @dealsignal/web dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "i18n:check": "pnpm --filter @dealsignal/web i18n:check && pnpm --filter @dealsignal/web i18n:no-hardcoded-strings",
    "db:migrate": "pnpm --filter @dealsignal/api db:migrate",
    "db:studio": "pnpm --filter @dealsignal/api db:studio",
    "db:start": "scripts/db-start.sh",
    "db:stop": "docker stop dealsignal-postgres && docker rm dealsignal-postgres"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.17",
    "eslint": "^9.26.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.1.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}
